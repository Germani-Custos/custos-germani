{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["core/**/*.js", "src/utils/**/*.js", "src/config/app-config.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
